{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "App": [
        "./admin-dashboard/src/App.tsx"
      ],
      "config": [
        "./admin-dashboard/src/config.ts"
      ],
      "components/*": [
        "./admin-dashboard/src/components/*"
      ],
      "config/*": [
        "./admin-dashboard/src/config/*"
      ],
      "data/*": [
        "./admin-dashboard/src/data/*"
      ],
      "helpers/*": [
        "./admin-dashboard/src/helpers/*"
      ],
      "hooks/*": [
        "./admin-dashboard/src/hooks/*"
      ],
      "layouts/*": [
        "./admin-dashboard/src/layouts/*"
      ],
      "lib/*": [
        "./admin-dashboard/src/lib/*"
      ],
      "pages/*": [
        "./admin-dashboard/src/pages/*"
      ],
      "providers/*": [
        "./admin-dashboard/src/providers/*"
      ],
      "reducers/*": [
        "./admin-dashboard/src/reducers/*"
      ],
      "routes/*": [
        "./admin-dashboard/src/routes/*"
      ],
      "theme/*": [
        "./admin-dashboard/src/theme/*"
      ],
      "types/*": [
        "./admin-dashboard/src/types/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules"
  ]
}
